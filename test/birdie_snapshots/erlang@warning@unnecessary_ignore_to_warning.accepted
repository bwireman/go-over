---
version: 2.0.0
title: Erlang@warning@unnecessary_ignore_to_warning
---
#(
  "missing-package",
  Warning(
    None,
    "missing-package",
    None,
    "Unnecessary ignore: package 'missing-package' is not a dependency",
    WarningReasonUnnecessaryIgnore,
    SeverityUnnecessaryIgnore,
    DirectDep,
  ),
)
